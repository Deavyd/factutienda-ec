{
  "name": "factutienda-pos",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.factutienda.pos",
    "productName": "FactuTienda EC",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend"
      }
    ]
  }
}
